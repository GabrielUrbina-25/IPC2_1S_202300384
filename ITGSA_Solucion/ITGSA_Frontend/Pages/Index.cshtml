@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mb-4">
    <h1>ITGSA - Tienda Virtual</h1>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🔴 Resetear</h5>
                <form method="post" asp-page-handler="Reset">
                    <button class="btn btn-danger w-100">Limpiar sistema</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">⚙️ Configuración</h5>
                <a href="/Configuracion" class="btn btn-primary w-100">Clientes / Bancos</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">💵 Transacciones</h5>
                <a href="/Transacciones" class="btn btn-success w-100">Facturas / Pagos</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">📋 Estado de Cuenta</h5>
                <a href="/EstadoCuenta" class="btn btn-info w-100 text-white">Consultar cuenta</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">📊 Ingresos por Banco</h5>
                <a href="/Ingresos" class="btn btn-warning w-100">Ver gráficas</a>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Mensaje))
{
    <div class="alert alert-info mt-4"><pre>@Model.Mensaje</pre></div>
}